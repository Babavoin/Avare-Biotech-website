<script>
(function(){
  function fixVideo(){
    if(window.innerWidth<=640){
      var clip=document.getElementById('mvtp-video-clip');
      if(clip){clip.style.cssText='max-width:75%!important;width:auto!important;margin:0 auto!important;border-radius:20px!important;overflow:hidden!important;box-shadow:0 20px 60px rgba(0,0,0,0.6)!important;line-height:0!important;display:block!important;margin-bottom:36px!important;';}
    }
  }
  fixVideo();
  window.addEventListener('resize',fixVideo);
})();
(function(){
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('visible');});
  },{threshold:0.1});
  document.querySelectorAll('#mvtp-page .reveal').forEach(function(el){obs.observe(el);});
})();
(function(){
  try{if(localStorage.getItem('mvtp_cookie_consent')){document.getElementById('mvtp-cookie').classList.add('m-cookie-hidden');}}catch(e){}
})();
function pvipCookieAccept(){
  try{localStorage.setItem('mvtp_cookie_consent','accepted');}catch(e){}
  document.getElementById('mvtp-cookie').classList.add('m-cookie-hidden');
}
function pvipCookieDecline(){
  try{localStorage.setItem('mvtp_cookie_consent','declined');}catch(e){}
  document.getElementById('mvtp-cookie').classList.add('m-cookie-hidden');
}
async function submitEarlyBird(){
  var email=document.getElementById('eb-email').value.trim();
  if(!email||!email.includes('@')){alert('Please enter a valid email.');return;}
  var btn=document.querySelector('.m-earlybird-btn');
  btn.disabled=true;btn.textContent='Sending...';
  var SCRIPT_URL='https://script.google.com/macros/s/AKfycbwuKsYVg_3x3RbBnxY0RUlFjE4tldmErUWRddqPDXg4xQxsOqqT19wTeGsxRqcW5jyK/exec';
  try{await fetch(SCRIPT_URL+'?'+new URLSearchParams({email:email,type:'earlybird'}).toString(),{method:'GET',mode:'no-cors'});}catch(e){}
  var s=document.getElementById('eb-success');
  s.setAttribute('style','display:block!important;margin-top:14px');
  btn.style.display='none';
  document.getElementById('eb-email').style.display='none';
}
async function submitMVTPForm(){
  var name=document.getElementById('f-name').value.trim();
  var phone=document.getElementById('f-phone').value.trim();
  var location=document.getElementById('f-location').value.trim();
  var link=document.getElementById('f-link').value.trim();
  var why=document.getElementById('f-why').value.trim();
  if(!name||!phone||!location||!link||!why){alert('Please fill in all required fields.');return;}
  var btn=document.querySelector('.m-form-submit');
  btn.disabled=true;btn.textContent='Sending...';
  var SCRIPT_URL='https://script.google.com/macros/s/AKfycbwuKsYVg_3x3RbBnxY0RUlFjE4tldmErUWRddqPDXg4xQxsOqqT19wTeGsxRqcW5jyK/exec';
  var params=new URLSearchParams({name:name,phone:phone,location:location,link:link,why:why});
  try{await fetch(SCRIPT_URL+'?'+params.toString(),{method:'GET',mode:'no-cors'});}catch(e){}
  document.getElementById('formContent').setAttribute('style','display:none!important');
  document.getElementById('formSuccess').setAttribute('style','display:block!important;text-align:center;padding:48px 0');
}
</script>
